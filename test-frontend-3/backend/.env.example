# ========================================
# offbyte Production-Ready Configuration
# ========================================
# WARNING: Never commit this file to version control!
# Add .env to your .gitignore immediately

# ========================================
# Server Configuration
# ========================================
NODE_ENV=development
PORT=5000
DEBUG=true

# Server URL (Update in production)
SERVER_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# ========================================
# Database Configuration
# ========================================
# MongoDB
MONGODB_URI=mongodb://localhost:27017/offbyte
# For MongoDB Atlas (Production):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/offbyte?retryWrites=true&w=majority
MONGODB_OPTIONS=retryWrites=true&w=majority

# ========================================
# JWT Authentication
# ========================================
# CRITICAL: Generate strong secret in production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_CHANGE_IN_PRODUCTION_use_64_chars_minimum
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_DIFFERENT_from_access_token
JWT_REFRESH_EXPIRE=30d

# Token Settings
ACCESS_TOKEN_EXPIRE=15m
REFRESH_TOKEN_EXPIRE=30d

# ========================================
# Security Configuration
# ========================================
# CORS Settings
CORS_ORIGIN=http://localhost:3000
# For multiple origins: https://app.com,https://admin.app.com
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# Request Size Limits
MAX_JSON_SIZE=10mb
MAX_URL_ENCODED_SIZE=10mb
MAX_FILE_SIZE=50mb

# Security Headers
HELMET_ENABLED=true

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_ERROR_FILE=./logs/error.log

# ========================================
# External Services & API Keys
# ========================================
# Add your API keys here
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# STRIPE_SECRET_KEY=
# SENDGRID_API_KEY=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ========================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ========================================
# [ ] Change NODE_ENV to 'production'
# [ ] Generate secure JWT_SECRET (64+ characters)
# [ ] Update database credentials
# [ ] Set proper CORS_ORIGIN
# [ ] Enable rate limiting
# [ ] Configure HTTPS
# [ ] Set SESSION_SECURE=true (if using sessions)
# [ ] Review and update all API keys
# [ ] Setup monitoring and logging
# [ ] Configure backup strategy
# [ ] Test error handling
